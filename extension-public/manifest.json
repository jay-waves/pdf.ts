{
  "manifest_version": 3,
  "name": "PDF Viewer",
  "description": "Open local PDF files with PDF Viewer.",
  "version": "0.3.4",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_title": "Open PDF Viewer",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "host_permissions": [
    "file:///*"
  ],
  "permissions": [
    "tabs"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'; connect-src 'self' file: blob: data:;"
  },
  "file_handlers": [
    {
      "action": "/viewer.html",
      "name": "Open PDF",
      "icons": {
        "16": "logo.png",
        "32": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
      },
      "accept": {
        "application/pdf": [
          ".pdf"
        ]
      },
      "launch_type": "single-client"
    }
  ]
}
